#!/usr/bin/env bash
# Install dotfiles for current or given host. See STRUCTURE.md for layout and roles.

set -e

BASE_CONFIG="base"
CONFIG_SUFFIX=".yaml"

META_DIR="meta"
CONFIG_DIR="roles"
PROFILES_DIR="hosts"

DOTBOT_DIR="dotbot"
DOTBOT_BIN="bin/dotbot"

BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${BASE_DIR}"

detect_host() {
  case "$OSTYPE" in
    darwin*)
      echo "osx"
      ;;
    linux*)
      if grep docker /proc/1/cgroup -qa; then
        echo "docker"
      elif grep -qE "(Microsoft|WSL)" /proc/version &> /dev/null; then
        echo "wsl"
      else
        echo "unix"
      fi
      ;;
    *)
      echo "unknown platform: $OSTYPE. Aborting" >&2
      return 1
      ;;
  esac
}

parse_dotbot_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --bootstrap)
        DOTFILES_BOOTSTRAP=1
        shift
        ;;
      --only|--except)
        DOTBOT_ARGS+=("$1")
        shift
        while [ "$#" -gt 0 ] && [[ "$1" != -* ]]; do
          DOTBOT_ARGS+=("$1")
          shift
        done
        ;;
      --plugin|-p)
        local option="$1"
        DOTBOT_ARGS+=("$option")
        shift
        if [ "$#" -eq 0 ]; then
          echo "Missing value for ${option}" >&2
          return 1
        fi
        DOTBOT_ARGS+=("$1")
        shift
        ;;
      --dry-run|-n|--verbose|-v|-vv|--quiet|-q|--force-color|--no-color|--version|--help|-h|--exit-on-failure|-x|--disable-built-in-plugins)
        DOTBOT_ARGS+=("$1")
        shift
        ;;
      -*)
        DOTBOT_ARGS+=("$1")
        shift
        ;;
      *)
        EXTRA_ROLES+=("$1")
        shift
        ;;
    esac
  done
}

has_dry_run() {
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --dry-run|-n)
        return 0
        ;;
    esac
  done
  return 1
}

run_package_bootstrap() {
  local role="$1"
  local package_args=(--host "${_ENV}" --role "${role}")

  if has_dry_run "${DOTBOT_ARGS[@]}"; then
    package_args+=(--dry-run)
  fi

  if [ "${DOTFILES_BOOTSTRAP:-}" = "1" ]; then
    package_args+=(--bootstrap)
  fi

  python3 helpers/package_bootstrap.py "${package_args[@]}"
}

# Refuse to run when both the `zsh` (plain) and `ohmyzsh` roles are scheduled:
# they both manage ~/.zshrc (the `zsh` role forces it, the `ohmyzsh` role
# links ~/.ohmyzshrc and copies into ~/.oh-my-zsh) and combining them yields
# unpredictable ordering depending on which dotbot run wins. AGENTS.md and
# STRUCTURE.md document the exclusion; this guard enforces it.
validate_role_exclusion() {
  local zsh_present=0
  local ohmyzsh_present=0
  local role
  for role in "$@"; do
    case "${role}" in
      zsh) zsh_present=1 ;;
      ohmyzsh) ohmyzsh_present=1 ;;
    esac
  done
  if [ "${zsh_present}" -eq 1 ] && [ "${ohmyzsh_present}" -eq 1 ]; then
    echo "error: the 'zsh' and 'ohmyzsh' roles are mutually exclusive." >&2
    echo "       Both manage ~/.zshrc; pick one before re-running." >&2
    return 1
  fi
}
if [ "$#" -gt 0 ] && [[ "$1" != -* ]]; then
  _ENV="$1"
  shift
else
  _ENV="$(detect_host)"
fi

if [ ! -f "${META_DIR}/${PROFILES_DIR}/${_ENV}${CONFIG_SUFFIX}" ]; then
  echo "Host type ${_ENV} is not supported."
  exit 1
fi

CONFIGS=()
EXTRA_ROLES=()
DOTBOT_ARGS=()

parse_dotbot_args "$@"

echo "Installing dotfiles for host type ${_ENV}"
if has_dry_run "${DOTBOT_ARGS[@]}"; then
  echo "Dry-run requested; skipping submodule update"
else
  submodule_args=(--init --recursive)
  if [ "${DOTFILES_UPDATE_SUBMODULES:-}" = "1" ]; then
    submodule_args+=(--remote)
    echo "Updating submodules from upstream remotes"
  else
    echo "Updating submodules to recorded commits"
  fi

  if ! git submodule update "${submodule_args[@]}"; then
    exit 1
  fi
fi

while IFS= read -r config; do
  config=${config#- }
  config=${config%%:*}
  [ -n "${config}" ] && CONFIGS+=("${config}")
done < "${META_DIR}/${PROFILES_DIR}/${_ENV}${CONFIG_SUFFIX}"

validate_role_exclusion "${CONFIGS[@]}" "${EXTRA_ROLES[@]}"

_dotbot=("${BASE_DIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASE_DIR}" --plugin dotbot-brew)

"${_dotbot[@]}" -c "${META_DIR}/${BASE_CONFIG}${CONFIG_SUFFIX}" "${DOTBOT_ARGS[@]}"

for config in "${CONFIGS[@]}" "${EXTRA_ROLES[@]}"; do
  run_package_bootstrap "${config}"
  "${_dotbot[@]}" -c "${META_DIR}/${CONFIG_DIR}/${config}${CONFIG_SUFFIX}" "${DOTBOT_ARGS[@]}"
  echo -e "Configured $config"
done
