#!/usr/bin/env bash

set -e

CONFIG_SUFFIX=".yaml"

META_DIR="meta"
CONFIG_DIR="roles"

DOTBOT_DIR="dotbot"
DOTBOT_BIN="bin/dotbot"

BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${BASE_DIR}"

usage() {
  cat <<'USAGE'
Usage: ./install-role <roles...> [dotbot-options...]
       ./install-role [dotbot-options...] <roles...>

Examples:
  ./install-role bash
  ./install-role bash --dry-run
  ./install-role --dry-run bash
USAGE
}

parse_dotbot_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --bootstrap)
        DOTFILES_BOOTSTRAP=1
        shift
        ;;
      --only|--except)
        DOTBOT_ARGS+=("$1")
        shift
        while [ "$#" -gt 0 ] && [[ "$1" != -* ]]; do
          DOTBOT_ARGS+=("$1")
          shift
        done
        ;;
      --plugin|-p)
        local option="$1"
        DOTBOT_ARGS+=("$option")
        shift
        if [ "$#" -eq 0 ]; then
          echo "Missing value for ${option}" >&2
          return 1
        fi
        DOTBOT_ARGS+=("$1")
        shift
        ;;
      --dry-run|-n|--verbose|-v|-vv|--quiet|-q|--force-color|--no-color|--version|--help|-h|--exit-on-failure|-x|--disable-built-in-plugins)
        DOTBOT_ARGS+=("$1")
        shift
        ;;
      -*)
        DOTBOT_ARGS+=("$1")
        shift
        ;;
      *)
        ROLES+=("$1")
        shift
        ;;
    esac
  done
}

detect_host() {
  case "$OSTYPE" in
    darwin*)
      echo "osx"
      ;;
    linux*)
      if grep docker /proc/1/cgroup -qa; then
        echo "docker"
      elif grep -qE "(Microsoft|WSL)" /proc/version &> /dev/null; then
        echo "wsl"
      else
        echo "unix"
      fi
      ;;
    *)
      echo "unknown"
      ;;
  esac
}

has_dry_run() {
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --dry-run|-n)
        return 0
        ;;
    esac
  done
  return 1
}

run_package_bootstrap() {
  local role="$1"
  local package_args=(--host "${_ENV}" --role "${role}")

  if has_dry_run "${DOTBOT_ARGS[@]}"; then
    package_args+=(--dry-run)
  fi

  if [ "${DOTFILES_BOOTSTRAP:-}" = "1" ]; then
    package_args+=(--bootstrap)
  fi

  python3 helpers/package_bootstrap.py "${package_args[@]}"
}

# Refuse to run when both the `zsh` (plain) and `ohmyzsh` roles are scheduled:
# they both manage ~/.zshrc and combining them yields unpredictable ordering.
# AGENTS.md and STRUCTURE.md document the exclusion; this guard enforces it
# even for partial role-only invocations like `./install-role zsh ohmyzsh`.
validate_role_exclusion() {
  local zsh_present=0
  local ohmyzsh_present=0
  local role
  for role in "$@"; do
    case "${role}" in
      zsh) zsh_present=1 ;;
      ohmyzsh) ohmyzsh_present=1 ;;
    esac
  done
  if [ "${zsh_present}" -eq 1 ] && [ "${ohmyzsh_present}" -eq 1 ]; then
    echo "error: the 'zsh' and 'ohmyzsh' roles are mutually exclusive." >&2
    echo "       Both manage ~/.zshrc; pick one before re-running." >&2
    return 1
  fi
}

ROLES=()
DOTBOT_ARGS=()
_ENV="$(detect_host)"

parse_dotbot_args "$@"

if [ "${#ROLES[@]}" -eq 0 ]; then
  usage >&2
  exit 1
fi

validate_role_exclusion "${ROLES[@]}"

_dotbot=("${BASE_DIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASE_DIR}" --plugin dotbot-brew)

for config in "${ROLES[@]}"; do
  run_package_bootstrap "${config}"
  "${_dotbot[@]}" -c "${META_DIR}/${CONFIG_DIR}/${config}${CONFIG_SUFFIX}" --verbose "${DOTBOT_ARGS[@]}"
done
